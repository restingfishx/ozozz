// Prisma schema for Ozozz E-commerce

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Product table
model Product {
  id            String      @id @default(cuid())
  name          String
  description   String?
  price         Float
  originalPrice Float?
  images        String[]    // JSON array of image URLs
  category      String?
  specs         Json?       // 规格定义
  stock         Int         @default(0)
  status        String      @default("active") // active, inactive
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  cartItems     CartItem[]
}

// Cart table
model Cart {
  id        String     @id @default(cuid())
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Cart item table
model CartItem {
  id        String   @id @default(cuid())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  specs     Json?    // 用户选择的规格
  price     Float    // 下单时的价格
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
}

// Order table
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("pending") // pending, paid, shipped, completed, cancelled
  totalAmount     Float
  currency        String      @default("USD")
  shippingAddress Json        // 收货地址
  trackingNumber  String?
  stripeSessionId String?
  paidAt          DateTime?
  shippedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
}

// Order item table
model OrderItem {
  id           String   @id @default(cuid())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product  @relation(fields: [productId], references: [id])
  productId    String
  productName  String   // 下单时的商品名称
  productImage String?  // 下单时的商品图片
  specs        Json?    // 下单时的规格
  price        Float    // 下单时的单价
  quantity     Int
  subtotal     Float    // 小计
  createdAt    DateTime @default(now())
}

// Admin user table
model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
